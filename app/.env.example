# Game-server base URL for the app.
# Simulator/emulator on the same machine as the server: http://localhost:4000
# Physical device via Expo Go: use the dev machine's LAN IP, e.g. http://192.168.1.20:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# Analytics (PostHog) — OPTIONAL. Leave unset to disable: with no key the analytics wrapper is a
# pure no-op (loads no SDK, makes no network calls). Set both to enable event capture.
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
